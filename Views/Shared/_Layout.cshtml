<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Clinic Queue System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>

        body {
            background: #f5f6fa;
        }

        .navbar {
            background: #2f3640;
        }

            .navbar a {
                color: white !important;
                font-weight: 500;
            }

                .navbar a:hover {
                    color: #00a8ff !important;
                }

        .footer {
            background: #2f3640;
            color: white;
            padding: 10px;
            text-align: center;
        }

    </style>

</head>

<body>

    <nav class="navbar navbar-expand-lg">

        <div class="container-fluid">

            <a class="navbar-brand text-white" href="/">Clinic Queue</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" href="/Admin/Dashboard">Admin</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Admin/Users">Users</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Patient/MyAppointments">My Appointments</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Receptionist/Queue">Receptionist Queue</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/Doctor/Queue">Doctor Queue</a>
                    </li>

                </ul>

                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link" href="/Auth/Logout">Logout</a>
                    </li>

                </ul>

            </div>
        </div>
    </nav>


    <div class="container mt-4">

        @RenderBody()

    </div>


    <footer class="footer mt-5">

        © 2026 - Clinic Queue System

    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>